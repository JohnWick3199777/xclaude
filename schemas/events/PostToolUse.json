{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "PostToolUse",
  "title": "PostToolUse",
  "description": "Fired after a tool completes successfully.",
  "properties": {
    "cwd": {
      "type": "string",
      "description": "Working directory of the session."
    },
    "hook_event_name": {
      "type": "string",
      "description": "Name of the event (e.g. SessionStart)."
    },
    "session_id": {
      "type": "string",
      "description": "Unique session identifier."
    },
    "transcript_path": {
      "type": "string",
      "description": "Path to the session transcript JSONL file."
    },
    "tool_name": {
      "type": "string",
      "description": "Name of the tool that was called."
    },
    "tool_use_id": {
      "type": "string",
      "description": "Unique identifier for this tool call."
    },
    "permission_mode": {
      "type": "string",
      "description": "Current permission mode."
    },
    "tool_input": {
      "type": "object",
      "description": "Tool-specific input (opaque)."
    },
    "tool_response": {
      "type": "object",
      "description": "Tool-specific response (opaque)."
    }
  },
  "required": [
    "cwd",
    "hook_event_name",
    "session_id",
    "transcript_path",
    "tool_name",
    "tool_use_id",
    "permission_mode",
    "tool_input",
    "tool_response"
  ],
  "additionalProperties": false
}
