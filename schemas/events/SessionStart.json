{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "SessionStart",
  "title": "SessionStart",
  "description": "Fired once when a session begins.",
  "properties": {
    "cwd": {
      "type": "string",
      "description": "Working directory of the session."
    },
    "hook_event_name": {
      "type": "string",
      "description": "Name of the event (e.g. SessionStart)."
    },
    "session_id": {
      "type": "string",
      "description": "Unique session identifier."
    },
    "transcript_path": {
      "type": "string",
      "description": "Path to the session transcript JSONL file."
    },
    "model": {
      "type": "string",
      "description": "Model used for this session."
    },
    "source": {
      "type": "string",
      "description": "How the session was started (cli, api, etc.)."
    }
  },
  "required": [
    "cwd",
    "hook_event_name",
    "session_id",
    "transcript_path",
    "model",
    "source"
  ],
  "additionalProperties": false
}
