{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "Stop",
  "title": "Stop",
  "description": "Fired when Claude stops (end of a turn).",
  "properties": {
    "cwd": {
      "type": "string",
      "description": "Working directory of the session."
    },
    "hook_event_name": {
      "type": "string",
      "description": "Name of the event (e.g. SessionStart)."
    },
    "session_id": {
      "type": "string",
      "description": "Unique session identifier."
    },
    "transcript_path": {
      "type": "string",
      "description": "Path to the session transcript JSONL file."
    },
    "last_assistant_message": {
      "type": "string",
      "description": "The last message Claude produced."
    },
    "permission_mode": {
      "type": "string",
      "description": "Current permission mode."
    },
    "stop_hook_active": {
      "type": "boolean",
      "description": "Whether a stop hook is active."
    }
  },
  "required": [
    "cwd",
    "hook_event_name",
    "session_id",
    "transcript_path",
    "last_assistant_message",
    "permission_mode",
    "stop_hook_active"
  ],
  "additionalProperties": false
}
