{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "TaskCompleted",
  "title": "TaskCompleted",
  "description": "Fired when a task is completed.",
  "allOf": [{ "$ref": "_common.json" }],
  "properties": {
    "cwd": true, "hook_event_name": true, "session_id": true, "transcript_path": true,
    "task_id": { "type": "string", "description": "Identifier of the completed task." }
  },
  "additionalProperties": false
}
