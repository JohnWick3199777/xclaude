{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "UserPromptSubmit",
  "title": "UserPromptSubmit",
  "description": "Fired when the user submits a prompt.",
  "properties": {
    "cwd": {
      "type": "string",
      "description": "Working directory of the session."
    },
    "hook_event_name": {
      "type": "string",
      "description": "Name of the event (e.g. SessionStart)."
    },
    "session_id": {
      "type": "string",
      "description": "Unique session identifier."
    },
    "transcript_path": {
      "type": "string",
      "description": "Path to the session transcript JSONL file."
    },
    "prompt": {
      "type": "string",
      "description": "The user's prompt text."
    },
    "permission_mode": {
      "type": "string",
      "description": "Current permission mode."
    }
  },
  "required": [
    "cwd",
    "hook_event_name",
    "session_id",
    "transcript_path",
    "prompt",
    "permission_mode"
  ],
  "additionalProperties": false
}
