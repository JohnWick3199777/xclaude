{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "SubagentStop",
  "title": "SubagentStop",
  "description": "Fired when a subagent finishes.",
  "properties": {
    "cwd": {
      "type": "string",
      "description": "Working directory of the session."
    },
    "hook_event_name": {
      "type": "string",
      "description": "Name of the event (e.g. SessionStart)."
    },
    "session_id": {
      "type": "string",
      "description": "Unique session identifier."
    },
    "transcript_path": {
      "type": "string",
      "description": "Path to the session transcript JSONL file."
    },
    "agent_id": {
      "type": "string",
      "description": "Unique identifier for the subagent."
    },
    "agent_transcript_path": {
      "type": "string",
      "description": "Path to the subagent's transcript."
    }
  },
  "required": [
    "cwd",
    "hook_event_name",
    "session_id",
    "transcript_path",
    "agent_id"
  ],
  "additionalProperties": false
}
