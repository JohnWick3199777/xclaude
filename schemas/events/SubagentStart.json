{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "SubagentStart",
  "title": "SubagentStart",
  "description": "Fired when a subagent is spawned.",
  "allOf": [{ "$ref": "_common.json" }],
  "properties": {
    "cwd": true, "hook_event_name": true, "session_id": true, "transcript_path": true,
    "agent_id":   { "type": "string", "description": "Unique identifier for the subagent." },
    "agent_type": { "type": "string", "description": "Type of the subagent." }
  },
  "required": ["agent_id"],
  "additionalProperties": false
}
