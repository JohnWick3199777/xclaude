{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "InstructionsLoaded",
  "title": "InstructionsLoaded",
  "description": "Fired when CLAUDE.md or memory files are loaded.",
  "properties": {
    "cwd": {
      "type": "string",
      "description": "Working directory of the session."
    },
    "hook_event_name": {
      "type": "string",
      "description": "Name of the event (e.g. SessionStart)."
    },
    "session_id": {
      "type": "string",
      "description": "Unique session identifier."
    },
    "transcript_path": {
      "type": "string",
      "description": "Path to the session transcript JSONL file."
    },
    "file_path": {
      "type": "string",
      "description": "Path to the loaded instructions file."
    },
    "load_reason": {
      "type": "string",
      "description": "Why instructions were loaded."
    },
    "memory_type": {
      "type": "string",
      "description": "Type of memory file (if applicable)."
    }
  },
  "required": [
    "cwd",
    "hook_event_name",
    "session_id",
    "transcript_path",
    "load_reason"
  ],
  "additionalProperties": false
}
