{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "WorktreeRemove",
  "title": "WorktreeRemove",
  "description": "Fired when a git worktree is removed.",
  "allOf": [{ "$ref": "_common.json" }],
  "properties": {
    "cwd": true, "hook_event_name": true, "session_id": true, "transcript_path": true,
    "worktree_path": { "type": "string", "description": "Path to the removed worktree." }
  },
  "additionalProperties": false
}
