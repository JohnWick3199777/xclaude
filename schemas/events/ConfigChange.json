{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ConfigChange",
  "title": "ConfigChange",
  "description": "Fired when a settings file changes.",
  "properties": {
    "cwd": {
      "type": "string",
      "description": "Working directory of the session."
    },
    "hook_event_name": {
      "type": "string",
      "description": "Name of the event (e.g. SessionStart)."
    },
    "session_id": {
      "type": "string",
      "description": "Unique session identifier."
    },
    "transcript_path": {
      "type": "string",
      "description": "Path to the session transcript JSONL file."
    },
    "source": {
      "type": "string",
      "description": "Source of the config change."
    },
    "file_path": {
      "type": "string",
      "description": "Path to the changed settings file."
    }
  },
  "required": [
    "cwd",
    "hook_event_name",
    "session_id",
    "transcript_path",
    "source",
    "file_path"
  ],
  "additionalProperties": false
}
