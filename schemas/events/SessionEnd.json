{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "SessionEnd",
  "title": "SessionEnd",
  "description": "Fired once when a session ends.",
  "properties": {
    "cwd": {
      "type": "string",
      "description": "Working directory of the session."
    },
    "hook_event_name": {
      "type": "string",
      "description": "Name of the event (e.g. SessionStart)."
    },
    "session_id": {
      "type": "string",
      "description": "Unique session identifier."
    },
    "transcript_path": {
      "type": "string",
      "description": "Path to the session transcript JSONL file."
    },
    "reason": {
      "type": "string",
      "description": "Why the session ended."
    }
  },
  "required": [
    "cwd",
    "hook_event_name",
    "session_id",
    "transcript_path",
    "reason"
  ],
  "additionalProperties": false
}
