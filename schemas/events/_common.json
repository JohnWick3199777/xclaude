{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "_common",
  "title": "Common Event Fields",
  "description": "Fields present on every Claude Code event.",
  "type": "object",
  "properties": {
    "cwd":             { "type": "string", "description": "Working directory of the session." },
    "hook_event_name": { "type": "string", "description": "Name of the event (e.g. SessionStart)." },
    "session_id":      { "type": "string", "description": "Unique session identifier." },
    "transcript_path": { "type": "string", "description": "Path to the session transcript JSONL file." }
  },
  "required": ["cwd", "hook_event_name", "session_id", "transcript_path"]
}
